/* 头像：圆形 + 光标悬停翻转 */
.site-author-image
  width: 120px
  height: 120px
  border-radius: 50%
  object-fit: cover
  transition: transform .7s ease, box-shadow .3s ease
  transform-style: preserve-3d
  backface-visibility: hidden
  box-shadow: 0 2px 8px rgba(0, 0, 0, .15)

.site-author-image:hover
  transform: rotateY(180deg)
  box-shadow: 0 6px 16px rgba(0, 0, 0, .25)

/* 网易云播放器样式 */
.links-of-blogroll-list iframe
  max-width: 100%
  border-radius: 4px

/* 评论区：尽量屏蔽 LiveRe 广告元素，不影响主体评论 */
#lv-container [id*="ad"],
#lv-container [class*="ad-"],
#lv-container [class*="ads"],
#lv-container [class*="sponsor"],
#lv-container [class*="recommend"],
#lv-container iframe[src*="ad"],
#lv-container iframe[src*="doubleclick"],
#lv-container iframe[src*="googlesyndication"]
  display: none !important

// Pisces：桌面端让主栏随视口变宽（上限约 1580px），正文区约为「主栏 − 侧栏 − 间距」
// 解决仅改变量时大屏上观感变化不明显的问题
@media (min-width: 992px)
  .header
    width: s('min(100vw - 40px, 1580px)') !important
  .header-inner
    width: 100% !important
    max-width: 100% !important
  .container .main-inner
    width: s('min(100vw - 40px, 1580px)') !important
  .footer-inner
    width: s('min(100vw - 40px, 1580px)') !important
  .content-wrap
    width: s('calc(100% - 260px)') !important
    max-width: 1320px
    box-sizing: border-box

